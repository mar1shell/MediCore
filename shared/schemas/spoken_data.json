{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "spoken_data",
  "title": "SpokenData",
  "description": "Structured entities extracted from the patient's spoken history via voice agent",
  "type": "object",
  "required": ["allergies", "medications", "diagnosis"],
  "properties": {
    "allergies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Allergies mentioned by patient verbally"
    },
    "medications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Medications mentioned by patient verbally"
    },
    "diagnosis": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Diagnoses mentioned by patient verbally"
    }
  },
  "additionalProperties": false
}
