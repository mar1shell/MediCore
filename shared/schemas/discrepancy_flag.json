{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "discrepancy_flag",
  "title": "DiscrepancyFlag",
  "description": "A single discrepancy detected between chart data and spoken data",
  "type": "object",
  "required": ["severity", "field", "chart_val", "spoken_val", "message"],
  "properties": {
    "severity": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Clinical severity of the discrepancy"
    },
    "field": {
      "type": "string",
      "enum": ["allergies", "medications", "diagnosis"],
      "description": "Which field the discrepancy was found in"
    },
    "chart_val": {
      "type": "string",
      "description": "The value from the written chart"
    },
    "spoken_val": {
      "type": "string",
      "description": "The value from the spoken patient history"
    },
    "message": {
      "type": "string",
      "description": "Human-readable description of the discrepancy"
    }
  },
  "additionalProperties": false
}
