{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "chart_data",
  "title": "ChartData",
  "description": "Structured entities extracted from a patient chart or spoken history",
  "type": "object",
  "required": ["allergies", "medications", "diagnosis"],
  "properties": {
    "allergies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of known patient allergies"
    },
    "medications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of current medications"
    },
    "diagnosis": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of active diagnoses"
    }
  },
  "additionalProperties": false
}
